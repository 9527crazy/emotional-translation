{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@emotional-translation/shared": ["../shared/src/index.ts"],
      "@emotional-translation/shared/*": ["../shared/src/*"]
    },
    "composite": false,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["src", "../shared/src"]
}
